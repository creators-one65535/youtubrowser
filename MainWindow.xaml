<Window
    x:Class="Youtubrowser.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Youtubrowser">

    <Grid x:Name="RootGrid" Loaded="RootGrid_Loaded">
        <!-- 各タブのWebView2インスタンスをここに動的に追加する。
             通常はColumn0に表示中タブだけがVisible。右ペイン表示中はColumn1にもう1つ表示する -->
        <Grid x:Name="WebViewHost">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="RightPaneColumn" Width="0" />
            </Grid.ColumnDefinitions>
        </Grid>

        <!-- カーソルがウィンドウ上のどこかに来ると現れるホバーツールバー(兼タイトルバー)。
             表示判定はXAMLのPointerEnteredではなくGetCursorPosのポーリングで行う(MainWindow.xaml.cs参照)。 -->
        <Border x:Name="Toolbar"
                VerticalAlignment="Top"
                Background="#F0202020"
                IsHitTestVisible="False"
                PointerEntered="Toolbar_PointerEntered"
                PointerExited="Toolbar_PointerExited"
                GotFocus="Toolbar_GotFocus"
                LostFocus="Toolbar_LostFocus">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToolbarTransform" Y="-60" />
            </Border.RenderTransform>
            <Border.Resources>
                <Style TargetType="Button">
                    <Setter Property="FontSize" Value="12" />
                </Style>
                <Style TargetType="TextBox">
                    <Setter Property="FontSize" Value="12" />
                </Style>
            </Border.Resources>
            <Grid x:Name="ToolbarGrid" Margin="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 左列: ナビゲーション -->
                <StackPanel x:Name="BrowserButtonsPanel" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BackButton" Width="34" Height="26" Margin="2,0" Click="BackButton_Click" ToolTipService.ToolTip="戻る">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="10" />
                    </Button>
                    <Button x:Name="ForwardButton" Width="34" Height="26" Margin="2,0" Click="ForwardButton_Click" ToolTipService.ToolTip="進む">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72A;" FontSize="10" />
                    </Button>
                    <Button x:Name="ReloadButton" Width="34" Height="26" Margin="2,0" Click="ReloadButton_Click" ToolTipService.ToolTip="再読み込み">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72C;" FontSize="10" />
                    </Button>
                    <Button x:Name="HomeButton" Width="34" Height="26" Margin="2,0"
                            Click="HomeButton_Click"
                            ToolTipService.ToolTip="ホーム">
                        <Button.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="現在のタブをホームに設定" Click="SetCurrentTabAsHome_Click" />
                            </MenuFlyout>
                        </Button.ContextFlyout>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE80F;" FontSize="10" />
                    </Button>
                    <TextBox x:Name="UrlBox" Width="300" Height="26" Margin="8,0,2,0" VerticalAlignment="Center"
                             KeyDown="UrlBox_KeyDown" ToolTipService.ToolTip="URLを直接入力、またはGoogle検索したい語句を入力">
                        <!-- 既定の右クリックメニュー(CommandBarFlyout)は非パッケージアプリで
                             ApplicationView.GetForCurrentView()が失敗してクラッシュする既知の不具合があるため、
                             シンプルなMenuFlyoutに差し替えて回避する -->
                        <TextBox.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="切り取り" Click="UrlBoxCut_Click" />
                                <MenuFlyoutItem Text="コピー" Click="UrlBoxCopy_Click" />
                                <MenuFlyoutItem Text="貼り付け" Click="UrlBoxPaste_Click" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="すべて選択" Click="UrlBoxSelectAll_Click" />
                            </MenuFlyout>
                        </TextBox.ContextFlyout>
                    </TextBox>
                    <Button x:Name="GoButton" Content="移動" Width="44" Height="26" Margin="2,0" Click="GoButton_Click" />
                </StackPanel>

                <!-- 中央列: タブ表示エリアが空き幅をすべて使う -->
                <Grid Grid.Column="1">
                    <Border x:Name="DragArea" Background="Transparent" SizeChanged="DragArea_SizeChanged" />
                    <Grid x:Name="TabBarPanel">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="TabScrollLeftButton" Grid.Column="0" Content="&lt;" Width="22" Height="24" Padding="0"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center" VerticalAlignment="Center"
                                Click="TabScrollLeftButton_Click" ToolTipService.ToolTip="左へスクロール" />
                        <ScrollViewer x:Name="TabStripScrollViewer" Grid.Column="1" Height="26" VerticalAlignment="Center"
                                      HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled">
                            <StackPanel x:Name="TabStripPanel" Orientation="Horizontal" VerticalAlignment="Center" />
                        </ScrollViewer>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="TabScrollRightButton" Content="&gt;" Width="22" Height="24" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="2,0" Click="TabScrollRightButton_Click" ToolTipService.ToolTip="右へスクロール" />
                            <Button x:Name="NewTabButton" Width="28" Height="26" Padding="0" Margin="4,0" Click="NewTabButton_Click" ToolTipService.ToolTip="新しいタブ">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="10" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- 右列: 拡張機能 + ウィンドウ操作 -->
                <StackPanel x:Name="WindowButtonsPanel" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="AddExtensionButton" Content="ADD" Height="26" Margin="2,0"
                            Background="#0078D4" Foreground="White"
                            Click="AddExtensionButton_Click" ToolTipService.ToolTip="拡張機能を追加..." />
                    <Button x:Name="MinimizeButton" Width="36" Height="26" Margin="16,0,2,0"
                            Background="#3A3A3A" Foreground="White"
                            Click="MinimizeButton_Click" ToolTipService.ToolTip="最小化">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE921;" FontSize="10" />
                    </Button>
                    <Button x:Name="MaximizeRestoreButton" Width="36" Height="26" Margin="2,0"
                            Background="#3A3A3A" Foreground="White"
                            Click="MaximizeRestoreButton_Click" ToolTipService.ToolTip="最大化">
                        <FontIcon x:Name="MaximizeRestoreIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE922;" FontSize="10" />
                    </Button>
                    <Button x:Name="CloseButton" Width="36" Height="26" Margin="2,0"
                            Background="#C42B1C" Foreground="White"
                            Click="CloseButton_Click" ToolTipService.ToolTip="閉じる">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8BB;" FontSize="10" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
